# Copy this file to `.env` and fill in the value. `.env` is gitignored.
#
# Web3Forms access key for the contact form. It is read in the browser, so it
# MUST keep the NEXT_PUBLIC_ prefix (Next.js only exposes NEXT_PUBLIC_* vars to
# the client). Web3Forms access keys are public by design — they ship in the
# client bundle, are rate-limited/spam-protected, and are tied to the
# destination inbox. Get one at https://web3forms.com.
#
# Note: Next.js inlines NEXT_PUBLIC_* at dev-server start — restart `pnpm dev`
# after changing this.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
